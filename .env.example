# ---------- App ----------
NEXT_PUBLIC_APP_URL=https://www.autofivestar.com
NEXT_PUBLIC_APP_NAME=AutoFiveStar

# ---------- Supabase ----------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
# Optional: only needed if DATABASE_URL uses Supabase pooler and project ref
# cannot be derived from NEXT_PUBLIC_SUPABASE_URL.
SUPABASE_PROJECT_REF=

# ---------- Database (Drizzle, postgres-js) ----------
# Pooled connection (PgBouncer / Supabase pooler) for app runtime
DATABASE_URL=postgresql://postgres:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# Direct connection for migrations
DIRECT_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# Optional (Neon only): required if your URL has no endpoint/user identifier
# and you connect through an IP/tunnel where SNI host is unavailable.
NEON_PROJECT_ID=

# ---------- Encryption ----------
# 32-byte key encoded as 64-char hex string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ---------- Google Business Profile OAuth ----------
# Separate Google OAuth client from Supabase Google login. Scope: business.manage
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
# Set to "true" only once Google has approved business.manage scope for this client
GBP_LIVE=false

# ---------- OpenAI ----------
OPENAI_API_KEY=
OPENAI_MODEL_PRIMARY=gpt-4o
OPENAI_MODEL_CLASSIFIER=gpt-4o-mini
# Set true once OPENAI_API_KEY is filled; when false (and NODE_ENV!=production)
# a deterministic fixture is returned instead of calling OpenAI.
AI_LIVE=false

# ---------- Stripe ----------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# ---------- Resend ----------
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@autofivestar.com
SUPPORT_EMAIL=support@autofivestar.com
# Set true once Resend domain is verified; when false (and NODE_ENV!=production)
# emails are fixture-sent (logged + notifications row marked sent with fixture:true)
EMAIL_LIVE=false

# ---------- Twilio (Growth/Pro SMS alerts on 1-2 star reviews) ----------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Set true once Twilio A2P 10DLC campaign is approved; when false (and
# NODE_ENV!=production) SMS is fixture-sent.
SMS_LIVE=false

# ---------- Yelp Fusion API (read-only) ----------
YELP_API_KEY=

# ---------- Upstash Redis (rate limits + queues) ----------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------- Inngest (background jobs) ----------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---------- PostHog (analytics) ----------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---------- Sentry (error tracking) ----------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
